Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", 
   RowBox[{
   "y", ",", "z", ",", "eps", ",", "sol3b", ",", "sol3c", ",", "stream"}], 
   "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Needs", "[", "\"\<NDSolve`FEM`\>\"", "]"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"eps", "=", "0.1"}], ";"}], "\[IndentingNewLine]", "\n", 
  RowBox[{
  "(*", "\:80cc\:666f\:6d41\:7ebf\:4e0e\:6162\:6d41\:5f62", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"stream", "=", 
    RowBox[{"StreamPlot", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"z", ",", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"y", "-", 
           RowBox[{"z", "*", "y", "*", 
            RowBox[{"(", 
             RowBox[{"1", "-", 
              RowBox[{"y", "^", "2"}]}], ")"}]}]}], ")"}], "/", "eps"}]}], 
       "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"y", ",", 
        RowBox[{"-", "2.5"}], ",", "2.5"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"z", ",", 
        RowBox[{"-", "4"}], ",", "4"}], "}"}], ",", 
      RowBox[{"StreamStyle", "->", "LightGray"}], ",", 
      RowBox[{"Epilog", "->", 
       RowBox[{"{", 
        RowBox[{"Red", ",", "Dashed", ",", "Thick", ",", 
         RowBox[{
          RowBox[{"Plot", "[", 
           RowBox[{
            RowBox[{"1", "/", 
             RowBox[{"(", 
              RowBox[{"1", "-", 
               RowBox[{"y", "^", "2"}]}], ")"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"y", ",", 
              RowBox[{"-", "2.5"}], ",", "2.5"}], "}"}], ",", 
            RowBox[{"Exclusions", "->", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"y", "==", 
                RowBox[{"-", "1"}]}], ",", 
               RowBox[{"y", "==", "1"}]}], "}"}]}]}], "]"}], "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], "}"}]}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"\:6c42\:89e3", " ", "3", 
       RowBox[{"(", "b", ")"}]}], ":", " ", 
      RowBox[{"\\", "alpha"}]}], "=", 
     RowBox[{"3", "/", "2"}]}], ",", " ", 
    RowBox[{
     RowBox[{"\\", "beta"}], "=", 
     RowBox[{
      RowBox[{"-", "3"}], "/", "2"}]}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"sol3b", "=", 
    RowBox[{"NDSolve", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"eps", "*", 
           RowBox[{
            RowBox[{"y", "''"}], "[", "x", "]"}]}], "+", 
          RowBox[{
           RowBox[{"y", "[", "x", "]"}], "*", 
           RowBox[{"(", 
            RowBox[{"1", "-", 
             RowBox[{
              RowBox[{"y", "[", "x", "]"}], "^", "2"}]}], ")"}], "*", 
           RowBox[{
            RowBox[{"y", "'"}], "[", "x", "]"}]}], "-", 
          RowBox[{"y", "[", "x", "]"}]}], "==", "0"}], ",", 
        RowBox[{
         RowBox[{"y", "[", "0", "]"}], "==", "1.5"}], ",", 
        RowBox[{
         RowBox[{"y", "[", "1", "]"}], "==", 
         RowBox[{"-", "1.5"}]}]}], "}"}], ",", "y", ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "0", ",", "1"}], "}"}], ",", 
      RowBox[{"Method", "->", 
       RowBox[{"{", 
        RowBox[{"\"\<PDEDiscretization\>\"", "->", 
         RowBox[{"{", 
          RowBox[{"\"\<FiniteElement\>\"", ",", 
           RowBox[{"\"\<MeshOptions\>\"", "->", 
            RowBox[{"{", 
             RowBox[{"\"\<MaxCellMeasure\>\"", "->", "0.001"}], "}"}]}]}], 
          "}"}]}], "}"}]}], ",", 
      RowBox[{"InitialSeeding", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"y", "[", "x", "]"}], "==", 
         RowBox[{"1.5", "-", 
          RowBox[{"3", "*", "x"}]}]}], "}"}]}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"\:6c42\:89e3", " ", "3", 
       RowBox[{"(", "c", ")"}]}], ":", " ", 
      RowBox[{"\\", "alpha"}]}], "=", 
     RowBox[{"1", "/", "2"}]}], ",", " ", 
    RowBox[{
     RowBox[{"\\", "beta"}], "=", "2"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"sol3c", "=", 
    RowBox[{"NDSolve", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"eps", "*", 
           RowBox[{
            RowBox[{"y", "''"}], "[", "x", "]"}]}], "+", 
          RowBox[{
           RowBox[{"y", "[", "x", "]"}], "*", 
           RowBox[{"(", 
            RowBox[{"1", "-", 
             RowBox[{
              RowBox[{"y", "[", "x", "]"}], "^", "2"}]}], ")"}], "*", 
           RowBox[{
            RowBox[{"y", "'"}], "[", "x", "]"}]}], "-", 
          RowBox[{"y", "[", "x", "]"}]}], "==", "0"}], ",", 
        RowBox[{
         RowBox[{"y", "[", "0", "]"}], "==", "0.5"}], ",", 
        RowBox[{
         RowBox[{"y", "[", "1", "]"}], "==", "2"}]}], "}"}], ",", "y", ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "0", ",", "1"}], "}"}], ",", 
      RowBox[{"Method", "->", 
       RowBox[{"{", 
        RowBox[{"\"\<PDEDiscretization\>\"", "->", 
         RowBox[{"{", 
          RowBox[{"\"\<FiniteElement\>\"", ",", 
           RowBox[{"\"\<MeshOptions\>\"", "->", 
            RowBox[{"{", 
             RowBox[{"\"\<MaxCellMeasure\>\"", "->", "0.001"}], "}"}]}]}], 
          "}"}]}], "}"}]}], ",", 
      RowBox[{"InitialSeeding", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"y", "[", "x", "]"}], "==", 
         RowBox[{"0.5", "+", 
          RowBox[{"1.5", "*", "x"}]}]}], "}"}]}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", "\:7ed8\:5236\:5e76\:7ec4\:5408", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"GraphicsGrid", "[", 
