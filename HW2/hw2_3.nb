        RowBox[{
         RowBox[{
          RowBox[{"eps", "*", 
           RowBox[{
            RowBox[{"y", "''"}], "[", "x", "]"}]}], "+", 
          RowBox[{
           RowBox[{"y", "[", "x", "]"}], "*", 
