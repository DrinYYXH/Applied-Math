          RowBox[{"y", "[", "x", "]"}]}], "==", "0"}], ",", 
        RowBox[{
         RowBox[{"y", "[", "0", "]"}], "==", "0.5"}], ",", 
        RowBox[{
         RowBox[{"y", "[", "1", "]"}], "==", "2"}]}], "}"}], ",", "y", ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "0", ",", "1"}], "}"}], ",", 
      RowBox[{"Method", "->", 
       RowBox[{"{", 
        RowBox[{"\"\<PDEDiscretization\>\"", "->", 
         RowBox[{"{", 
          RowBox[{"\"\<FiniteElement\>\"", ",", 
           RowBox[{"\"\<MeshOptions\>\"", "->", 
            RowBox[{"{", 
             RowBox[{"\"\<MaxCellMeasure\>\"", "->", "0.001"}], "}"}]}]}], 
          "}"}]}], "}"}]}], ",", 
      RowBox[{"InitialSeeding", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"y", "[", "x", "]"}], "==", 
         RowBox[{"0.5", "+", 
          RowBox[{"1.5", "*", "x"}]}]}], "}"}]}]}], "]"}]}], ";"}], 
