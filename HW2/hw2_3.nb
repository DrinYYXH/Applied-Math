 RowBox[{
  RowBox[{
   RowBox[{"sol3b", "=", 
    RowBox[{"NDSolve", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"eps", "*", 
           RowBox[{
            RowBox[{"y", "''"}], "[", "x", "]"}]}], "+", 
          RowBox[{
           RowBox[{"y", "[", "x", "]"}], "*", 
           RowBox[{"(", 
            RowBox[{"1", "-", 
             RowBox[{
              RowBox[{"y", "[", "x", "]"}], "^", "2"}]}], ")"}], "*", 
           RowBox[{
            RowBox[{"y", "'"}], "[", "x", "]"}]}], "-", 
          RowBox[{"y", "[", "x", "]"}]}], "==", "0"}], ",", 
        RowBox[{
         RowBox[{"y", "[", "0", "]"}], "==", "1.5"}], ",", 
        RowBox[{
         RowBox[{"y", "[", "1", "]"}], "==", 
         RowBox[{"-", "1.5"}]}]}], "}"}], ",", "y", ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "0", ",", "1"}], "}"}], ",", 
      RowBox[{"Method", "->", 
       RowBox[{"{", 
        RowBox[{"\"\<PDEDiscretization\>\"", "->", 
         RowBox[{"{", 
          RowBox[{"\"\<FiniteElement\>\"", ",", 
           RowBox[{"\"\<MeshOptions\>\"", "->", 
            RowBox[{"{", 
             RowBox[{"\"\<MaxCellMeasure\>\"", "->", "0.001"}], "}"}]}]}], 
          "}"}]}], "}"}]}], ",", 
      RowBox[{"InitialSeeding", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"y", "[", "x", "]"}], "==", 
         RowBox[{"1.5", "-", 
          RowBox[{"3", "*", "x"}]}]}], "}"}]}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\n", 
