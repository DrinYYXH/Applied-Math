Cell[CellGroupData[{
Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{"r1", ",", "r2", ",", "yExact", ",", "yComp"}], "]"}], ";"}], 
  "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Define", " ", "the", " ", "roots", " ", "of", " ", "the", " ", 
    "characteristic", " ", "equation"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"r1", "[", "eps_", "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "+", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"1", "-", 
        RowBox[{"2", "*", "eps"}]}], "]"}]}], ")"}], "/", "eps"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"r2", "[", "eps_", "]"}], ":=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "1"}], "-", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"1", "-", 
         RowBox[{"2", "*", "eps"}]}], "]"}]}], ")"}], "/", "eps"}]}], ";"}], 
  "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Define", " ", "the", " ", "Exact", " ", "Solution"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"yExact", "[", 
     RowBox[{"x_", ",", "eps_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"Exp", "[", 
           RowBox[{"r2", "[", "eps", "]"}], "]"}]}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Exp", "[", 
           RowBox[{"r1", "[", "eps", "]"}], "]"}], "-", 
          RowBox[{"Exp", "[", 
           RowBox[{"r2", "[", "eps", "]"}], "]"}]}], ")"}]}], ")"}], "*", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"r1", "[", "eps", "]"}], "*", "x"}], "]"}]}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Exp", "[", 
           RowBox[{"r1", "[", "eps", "]"}], "]"}], "-", "1"}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Exp", "[", 
           RowBox[{"r1", "[", "eps", "]"}], "]"}], "-", 
          RowBox[{"Exp", "[", 
           RowBox[{"r2", "[", "eps", "]"}], "]"}]}], ")"}]}], ")"}], "*", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"r2", "[", "eps", "]"}], "*", "x"}], "]"}]}]}]}], ";"}], "\n",
   "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Define", " ", "the", " ", "Composite", " ", "Approximate", " ", 
    "Solution"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"yComp", "[", 
     RowBox[{"x_", ",", "eps_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"Exp", "[", 
      RowBox[{"1", "-", "x"}], "]"}], "+", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{"Exp", "[", "1", "]"}]}], ")"}], "*", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", "2"}], "*", 
        RowBox[{"x", "/", "eps"}]}], "]"}]}]}]}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{
   "1.", " ", "Static", " ", "Plot", " ", "for", " ", "a", " ", "fixed", " ", 
    "epsilon"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"epsVal", "=", "0.05"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"yExact", "[", 
       RowBox[{"x", ",", "epsVal"}], "]"}], ",", 
      RowBox[{"yComp", "[", 
       RowBox[{"x", ",", "epsVal"}], "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0", ",", "1"}], "}"}], ",", 
    RowBox[{"PlotStyle", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Blue", ",", "Thick"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"Red", ",", "Dashed", ",", "Thick"}], "}"}]}], "}"}]}], ",", 
    RowBox[{"PlotLegends", "->", 
     RowBox[{"{", 
      RowBox[{"\"\<Exact Solution\>\"", 
       ",", "\"\<Composite Approximation\>\""}], "}"}]}], ",", 
    RowBox[{"AxesLabel", "->", 
     RowBox[{"{", 
      RowBox[{"\"\<x\>\"", ",", "\"\<y(x)\>\""}], "}"}]}], ",", 
    RowBox[{"PlotLabel", "->", 
     RowBox[{"Row", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<Matched Asymptotic Expansion Comparison (\[Epsilon] = \
\>\"", ",", "epsVal", ",", "\"\<)\>\""}], "}"}], "]"}]}], ",", 
    RowBox[{"PlotRange", "->", "All"}], ",", 
    RowBox[{"ImageSize", "->", "Large"}]}], "]"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "2.", " ", "Interactive", " ", "Plot", " ", "using", " ", "Manipulate"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"yExact", "[", 
       RowBox[{"x", ",", "eps"}], "]"}], ",", 
      RowBox[{"yComp", "[", 
       RowBox[{"x", ",", "eps"}], "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0", ",", "1"}], "}"}], ",", 
    RowBox[{"PlotStyle", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Blue", ",", "Thick"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"Red", ",", "Dashed", ",", "Thick"}], "}"}]}], "}"}]}], ",", 
    RowBox[{"PlotLegends", "->", 
     RowBox[{"{", 
      RowBox[{"\"\<Exact Solution\>\"", 
       ",", "\"\<Composite Approximation\>\""}], "}"}]}], ",", 
    RowBox[{"AxesLabel", "->", 
     RowBox[{"{", 
      RowBox[{"\"\<x\>\"", ",", "\"\<y(x)\>\""}], "}"}]}], ",", 
    RowBox[{"PlotLabel", "->", 
     RowBox[{"Row", "[", 
      RowBox[{"{", "\"\<Boundary Layer Behavior at x=0\>\"", "}"}], "]"}]}], ",", 
    RowBox[{"PlotRange", "->", "All"}], ",", 
    RowBox[{"ImageSize", "->", "Large"}]}], "]"}], ",", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "eps", ",", "0.1", ",", "\"\<\[Epsilon] (Perturbation Parameter)\>\""}], 
     "}"}], ",", "0.01", ",", "0.49", ",", "0.01", ",", 
    RowBox[{"Appearance", "->", "\"\<Labeled\>\""}]}], "}"}]}]}], "Input",
