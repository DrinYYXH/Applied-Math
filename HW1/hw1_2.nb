Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{"y", ",", "yNum", ",", "\[Tau]", ",", "\[CurlyEpsilon]"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"y", "[", 
    RowBox[{"\[Tau]_", ",", "\[CurlyEpsilon]_"}], "]"}], ":=", 
   RowBox[{"\[Tau]", "-", 
    RowBox[{
     RowBox[{"\[Tau]", "^", "2"}], "/", "2"}], "+", 
    RowBox[{"\[CurlyEpsilon]", "*", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"\[Tau]", "^", "3"}], "/", "3"}], "-", 
       RowBox[{
        RowBox[{"\[Tau]", "^", "4"}], "/", "12"}]}], ")"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"sol", "[", "\[CurlyEpsilon]_", "]"}], ":=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"yNum", "''"}], "[", "\[Tau]", "]"}], "==", 
        RowBox[{
         RowBox[{"-", "1"}], "/", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "+", 
            RowBox[{"\[CurlyEpsilon]", " ", 
             RowBox[{"yNum", "[", "\[Tau]", "]"}]}]}], ")"}], "^", "2"}]}]}], 
       ",", 
       RowBox[{
        RowBox[{"yNum", "[", "0", "]"}], "==", "0"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"yNum", "'"}], "[", "0", "]"}], "==", "1"}]}], "}"}], ",", 
     "yNum", ",", 
     RowBox[{"{", 
      RowBox[{"\[Tau]", ",", "0", ",", "2"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
