       RowBox[{
        RowBox[{"yNum", "[", "\[Tau]", "]"}], "/.", " ", 
        RowBox[{"sol", "[", "0", "]"}]}], "]"}], ",", 
      RowBox[{"y", "[", 
       RowBox[{"\[Tau]", ",", "0.001"}], "]"}], ",", 
      RowBox[{"Evaluate", "[", 
       RowBox[{
        RowBox[{"yNum", "[", "\[Tau]", "]"}], "/.", " ", 
        RowBox[{"sol", "[", "0.001", "]"}]}], "]"}], ",", 
      RowBox[{"y", "[", 
